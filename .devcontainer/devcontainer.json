{
  "name": "GRANITE Development",
  "image": "mcr.microsoft.com/devcontainers/python:3.11",
  "features": {
    "ghcr.io/devcontainers/features/docker-in-docker:2": {
      "moby": false
    }
  },
  "postStartCommand": "bash /workspaces/GRANITE/granite/scripts/start_osrm.sh",
  "forwardPorts": [5000, 5001],
  "portsAttributes": {
    "5000": {
      "label": "OSRM Driving",
      "onAutoForward": "ignore"
    },
    "5001": {
      "label": "OSRM Walking",
      "onAutoForward": "ignore"
    }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance"
      ]
    }
  }
}